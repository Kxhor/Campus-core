# ─────────────────────────────────────────────
# CampusCore — Environment Configuration Template
# ─────────────────────────────────────────────
# Copy this file to .env and fill in all values
# before starting the server locally or adding
# them to your Render dashboard.
# ─────────────────────────────────────────────

# ── Core Flask ──────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_long_random_string_here
FLASK_APP=app_legacy.py
FLASK_DEBUG=True

# ── Database ────────────────────────────────
# Local SQLite example: sqlite:///campuscore.db
# Render Postgres example: postgresql://user:pass@host/db
DATABASE_URL=sqlite:///campuscore.db

# ── Supabase (File Storage) ─────────────────
# Required for production file uploads (certificates, etc.)
# Get these from Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# ── Email Server ────────────────────────────
# Used for sending event notifications and OTPs
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=your_email@gmail.com

# ── Google OAuth (Optional) ─────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Security & Performance ──────────────────
# Comma-separated list of allowed domains for CORS
ALLOWED_ORIGINS=http://localhost:5000,https://your-render-app.onrender.com
# Set to 'True' in production to force HTTPS redirects
FORCE_HTTPS=False
# Inject demo data on startup (set to false in production)
INJECT_DEMO_DATA=False
