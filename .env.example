# ─────────────────────────────────────────────
# CampusCore — Environment Configuration Template
# Copy this file to .env and fill in all values
# before starting the server.
# ─────────────────────────────────────────────

# ── Core Flask ──────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# ── Database ─────────────────────────────────
# For SQLite (default, development only):
DATABASE_URL=sqlite:///campuscore.db
# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@host:5432/campuscore

# ── Production Flags ─────────────────────────
# Set to True only when SSL is configured on the server
FORCE_HTTPS=False
# Set to True only when deploying to production
PRODUCTION=False

# ── Demo Data ────────────────────────────────
# Set to True only on first run to seed test accounts
# NEVER set to True in production
INJECT_DEMO_DATA=False

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5000

# ── Email (Flask-Mail) ───────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=CampusCore SIST <your-email@gmail.com>

# ── QR Code ──────────────────────────────────
# Generate separately: python -c "import secrets; print(secrets.token_hex(16))"
QR_SECRET_KEY=replace-with-another-random-string

# ── Google OAuth (optional) ──────────────────
# Leave blank to hide the Google Sign-In button
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
